# Copy to /opt/taskqueue/.env.production and chmod 600.

IMAGE_REPOSITORY=ghcr.io/OWNER/REPOSITORY
IMAGE_TAG=REPLACE_WITH_COMMIT_SHA

API_DOMAIN=api.example.com
WS_DOMAIN=ws.example.com
ACME_EMAIL=ops@example.com

# Use URL-safe values. Hex output is suitable for both secrets.
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_HEX
JWT_SECRET=REPLACE_WITH_RANDOM_HEX
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_RANDOM_HEX

OPS_BIND_IP=127.0.0.1
LOG_LEVEL=info
KAFKA_LOG_RETENTION_HOURS=168
PROMETHEUS_RETENTION=15d

EMAIL_MAX_CONCURRENCY=5
IMAGE_MAX_CONCURRENCY=3
DATA_MAX_CONCURRENCY=8
