{
  "name": "@taskqueue/cli",
  "version": "1.0.0",
  "private": true,
  "description": "Command-line client for TaskQueue",
  "bin": {
    "taskqueue": "./dist/index.js",
    "tq": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "cli": "node --import tsx src/index.ts",
    "dev": "node --import tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "prettier --check src/ tests/"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
